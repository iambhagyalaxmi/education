generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Course {
  id                  String               @id @default(uuid()) @db.Uuid
  code                String               @unique
  name                String
  durationYears       Int
  description         String?
  createdAt           DateTime             @default(now())
  brochureUrl         String?
  applyUrl            String?
  applications        Application[]
  batches             Batch[]
  careerPaths         CareerPath[]
  eligibilityCriteria EligibilityCriteria?
  feeStructures       FeeStructure[]
  placement           Placement?
  scholarships        Scholarship[]
  students            Student[]
  subjects            Subject[]
}

model Subject {
  id         String     @id @default(uuid()) @db.Uuid
  courseId   String     @db.Uuid
  code       String     @unique
  name       String
  semester   Int
  credits    Int        @default(3)
  type       String     @default("core")
  createdAt  DateTime   @default(now())
  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  syllabuses Syllabus[]
}

model Syllabus {
  id          String   @id @default(uuid()) @db.Uuid
  subjectId   String   @db.Uuid
  title       String
  description String?
  topics      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model Semester {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  startDate DateTime
  endDate   DateTime
  status    String   @default("Upcoming")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeeStructure {
  id              String   @id @default(uuid()) @db.Uuid
  courseId        String   @db.Uuid
  academicYear    String
  admissionFee    Decimal  @db.Decimal(10, 2)
  tuitionFee      Decimal  @db.Decimal(10, 2)
  registrationFee Decimal  @db.Decimal(10, 2)
  totalFee        Decimal  @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, academicYear])
}

model Batch {
  id           String            @id @default(uuid()) @db.Uuid
  courseId     String            @db.Uuid
  academicYear String
  startYear    Int
  endYear      Int
  createdAt    DateTime          @default(now())
  course       Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  students     Student[]
  statistic    StudentStatistic?

  @@unique([courseId, academicYear])
}

model StudentStatistic {
  id                String   @id @default(uuid()) @db.Uuid
  batchId           String   @unique @db.Uuid
  totalEnrolled     Int      @default(0)
  studentsLeft      Int      @default(0)
  studentsGraduated Int      @default(0)
  updatedAt         DateTime @updatedAt
  batch             Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model Student {
  id                String             @id @default(uuid()) @db.Uuid
  courseId          String             @db.Uuid
  batchId           String             @db.Uuid
  firstName         String
  lastName          String
  email             String             @unique
  phone             String?
  profilePic        String?
  status            String             @default("active")
  joinedAt          DateTime           @default(now())
  hostelAllocations HostelAllocation[]
  batch             Batch              @relation(fields: [batchId], references: [id])
  course            Course             @relation(fields: [courseId], references: [id])
}

model Application {
  id           String   @id @default(uuid()) @db.Uuid
  courseId     String   @db.Uuid
  firstName    String
  lastName     String
  email        String
  phone        String?
  status       String   @default("pending")
  academicYear String
  appliedAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  course       Course   @relation(fields: [courseId], references: [id])
}

model User {
  id                String             @id @default(uuid()) @db.Uuid
  name              String
  email             String             @unique
  phone             String?
  googleId          String?            @unique
  role              String             @default("student")
  department        String?
  isActive          Boolean            @default(true)
  profilePic        String?
  lastLoginAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @default(now()) @updatedAt
  auditLogs         AuditLog[]
  conversations     Conversation[]
  uploadedDocs      Document[]
  documentDownloads DocumentDownload[]
  leaveRequests     LeaveRequest[]
  payrollRecords    PayrollRecord[]
  tickets           Ticket[]
}

model Conversation {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String?    @db.Uuid
  sessionId String?
  status    String     @default("active")
  startedAt DateTime   @default(now())
  endedAt   DateTime?
  user      User?      @relation(fields: [userId], references: [id])
  feedback  Feedback[]
  messages  Message[]
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @db.Uuid
  sender         String
  content        String
  intent         String?
  timestamp      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model Ticket {
  id           String   @id @default(uuid()) @db.Uuid
  ticketNumber String   @unique
  userId       String?  @db.Uuid
  sessionId    String?
  title        String
  description  String
  category     String
  priority     String   @default("medium")
  status       String   @default("open")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User?    @relation(fields: [userId], references: [id])
}

model Feedback {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @db.Uuid
  rating         Int
  comments       String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model AuditLog {
  logId        String   @id @default(uuid()) @db.Uuid
  userId       String?  @db.Uuid
  userRole     String?
  actionType   String
  tableName    String
  recordId     String
  oldValue     Json?
  newValue     Json?
  changeReason String?
  ipAddress    String?
  deviceInfo   String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id])

  @@index([tableName, recordId])
  @@index([actionType])
  @@index([createdAt])
}

model DocumentCategory {
  id          String     @id @default(uuid()) @db.Uuid
  name        String     @unique
  description String?
  documents   Document[]
}

model Document {
  id           String             @id @default(uuid()) @db.Uuid
  title        String
  categoryId   String             @db.Uuid
  description  String
  keywords     String[]
  academicYear String?
  department   String?
  version      String             @default("1.0")
  fileUrl      String
  fileType     String
  fileSize     Int
  language     String             @default("English")
  status       String             @default("active")
  uploadedById String?            @db.Uuid
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  category     DocumentCategory   @relation(fields: [categoryId], references: [id])
  uploadedBy   User?              @relation(fields: [uploadedById], references: [id])
  downloads    DocumentDownload[]

  @@index([title])
}

model DocumentDownload {
  id           String   @id @default(uuid()) @db.Uuid
  documentId   String   @db.Uuid
  userId       String?  @db.Uuid
  sessionId    String?
  downloadDate DateTime @default(now())
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user         User?    @relation(fields: [userId], references: [id])
}

model EligibilityCriteria {
  id             String   @id @default(uuid()) @db.Uuid
  courseId       String   @unique @db.Uuid
  requiredQuals  String[]
  allowedStreams String[]
  minPercentage  Float
  description    String?
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Scholarship {
  id            String    @id @default(uuid()) @db.Uuid
  courseId      String?   @db.Uuid
  name          String
  description   String?
  eligibility   String
  minPercentage Float?
  amount        String
  deadline      DateTime?
  course        Course?   @relation(fields: [courseId], references: [id])
}

model Placement {
  id            String   @id @default(uuid()) @db.Uuid
  courseId      String   @unique @db.Uuid
  placementRate Float
  averageSalary String
  topRecruiters String[]
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model CareerPath {
  id             String  @id @default(uuid()) @db.Uuid
  courseId       String  @db.Uuid
  roleName       String
  industryDemand String?
  course         Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model GalleryImage {
  id          String   @id @default(uuid()) @db.Uuid
  url         String
  title       String
  description String?
  category    String
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HostelRoom {
  id          String             @id @default(uuid()) @db.Uuid
  roomNumber  String
  block       String
  roomType    String
  totalBeds   Int
  status      String             @default("Available")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  allocations HostelAllocation[]
}

model HostelAllocation {
  id        String     @id @default(uuid()) @db.Uuid
  studentId String     @db.Uuid
  roomId    String     @db.Uuid
  status    String     @default("Allocated")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  room      HostelRoom @relation(fields: [roomId], references: [id])
  student   Student    @relation(fields: [studentId], references: [id])
}

model TransportVehicle {
  id          String           @id @default(uuid()) @db.Uuid
  vehicleId   String           @unique
  type        String
  plateNumber String
  condition   String
  status      String           @default("Active")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  routes      TransportRoute[]
}

model TransportRoute {
  id        String            @id @default(uuid()) @db.Uuid
  routeNo   String            @unique
  name      String
  path      String
  vehicleId String?           @db.Uuid
  stops     Int
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  vehicle   TransportVehicle? @relation(fields: [vehicleId], references: [id])
}

model PayrollRecord {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  month      String
  baseSalary String
  allowances String
  netPayable String
  status     String   @default("Pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
}

model LeaveRequest {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  type      String
  duration  String
  reason    String
  status    String   @default("Pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model AdmissionApplication {
  id        String   @id @default(uuid()) @db.Uuid
  appId     String   @unique
  name      String
  course    String
  date      String
  status    String   @default("Pending")
  score     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeeRecord {
  id        String   @id @default(uuid()) @db.Uuid
  student   String
  course    String
  amount    String
  dueDate   String
  status    String   @default("Pending")
  invoiceNo String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Examination {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  course    String
  date      String
  time      String
  room      String
  status    String   @default("Upcoming")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GradingScale {
  id        String   @id @default(uuid()) @db.Uuid
  grade     String   @unique
  minScore  Int
  maxScore  Int
  gpa       Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LibraryBook {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  author    String
  isbn      String   @unique
  category  String
  qty       Int      @default(1)
  status    String   @default("In Stock")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  code      String   @unique
  hod       String?
  faculty   Int      @default(0)
  students  Int      @default(0)
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TimetableEntry {
  id        String   @id @default(uuid()) @db.Uuid
  day       String
  time      String
  subject   String
  faculty   String
  room      String
  course    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Classroom {
  id        String   @id @default(uuid()) @db.Uuid
  room      String
  type      String
  capacity  Int
  building  String
  status    String   @default("Available")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Announcement {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  content   String?
  audience  String
  status    String   @default("Published")
  createdAt DateTime @default(now())
}

model AppMessage {
  id        String   @id @default(uuid()) @db.Uuid
  type      String
  audience  String
  subject   String?
  body      String
  createdAt DateTime @default(now())
}

model TransportDriver {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  license   String   @unique
  vehicle   String
  route     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model InternalChat {
  id        String                @id @default(uuid()) @db.Uuid
  name      String?
  type      String                @default("Group")
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  messages  InternalChatMessage[]
}

model InternalChatMessage {
  id        String       @id @default(uuid()) @db.Uuid
  chatId    String       @db.Uuid
  senderId  String
  senderName String
  content   String
  createdAt DateTime     @default(now())
  
  chat      InternalChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

model LessonPlan {
  id          String   @id @default(uuid()) @db.Uuid
  topic       String
  date        DateTime
  duration    Int
  objectives  String
  tool        String   @default("Standard Tool")
  status      String   @default("Pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
