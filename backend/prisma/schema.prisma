generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Core Education Data ───────────────────────────────────────────────────────

model Course {
  id             String          @id @default(uuid()) @db.Uuid
  code           String          @unique // BCA, BSc, MCA, BTech
  name           String
  durationYears  Int
  description    String?
  createdAt      DateTime        @default(now())
  feeStructures       FeeStructure[]
  batches             Batch[]
  students            Student[]
  applications        Application[]
  eligibilityCriteria EligibilityCriteria?
  scholarships        Scholarship[]
  placement           Placement?
  careerPaths         CareerPath[]
  brochureUrl         String? 
  applyUrl            String? 
}

model FeeStructure {
  id              String   @id @default(uuid()) @db.Uuid
  courseId        String   @db.Uuid
  academicYear    String   // e.g., "2024-2025"
  admissionFee    Decimal  @db.Decimal(10, 2)
  tuitionFee      Decimal  @db.Decimal(10, 2)
  registrationFee Decimal  @db.Decimal(10, 2)
  totalFee        Decimal  @db.Decimal(10, 2)
  createdAt       DateTime @default(now())

  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, academicYear])
}

model Batch {
  id           String            @id @default(uuid()) @db.Uuid
  courseId     String            @db.Uuid
  academicYear String            // e.g., "2024-2027"
  startYear    Int
  endYear      Int
  createdAt    DateTime          @default(now())

  course       Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  students     Student[]
  statistic    StudentStatistic?

  @@unique([courseId, academicYear])
}

model StudentStatistic {
  id                String   @id @default(uuid()) @db.Uuid
  batchId           String   @unique @db.Uuid
  totalEnrolled     Int      @default(0)
  studentsLeft      Int      @default(0)
  studentsGraduated Int      @default(0)
  updatedAt         DateTime @updatedAt

  batch             Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model Student {
  id        String   @id @default(uuid()) @db.Uuid
  courseId  String   @db.Uuid
  batchId   String   @db.Uuid
  firstName String
  lastName  String
  email     String   @unique
  phone     String?
  status    String   @default("active") // active, graduated, dropped
  joinedAt  DateTime @default(now())

  course    Course   @relation(fields: [courseId], references: [id])
  batch     Batch    @relation(fields: [batchId], references: [id])
  hostelAllocations HostelAllocation[]
}

model Application {
  id           String   @id @default(uuid()) @db.Uuid
  courseId     String   @db.Uuid
  firstName    String
  lastName     String
  email        String
  phone        String?
  status       String   @default("pending") // pending, approved, rejected
  academicYear String
  appliedAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  course       Course   @relation(fields: [courseId], references: [id])
}

// ─── Existing Support/Chat Data ───────────────────────────────────────────────

model User {
  id            String         @id @default(uuid()) @db.Uuid
  name          String
  email         String         @unique
  phone         String?
  googleId      String?        @unique
  role          String         @default("student") // student, counselor, faculty, staff, admin
  department    String?        // e.g., Computer Science, Admissions
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now()) @updatedAt

  conversations     Conversation[]
  tickets           Ticket[]
  auditLogs         AuditLog[]
  uploadedDocs      Document[]
  documentDownloads DocumentDownload[]
  payrollRecords    PayrollRecord[]
  leaveRequests     LeaveRequest[]
}

model Conversation {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String?   @db.Uuid
  sessionId String?   // For anonymous sessions
  status    String    @default("active") // active, closed
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  user      User?      @relation(fields: [userId], references: [id])
  messages  Message[]
  feedback  Feedback[]
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @db.Uuid
  sender         String       // "user", "bot", "agent"
  content        String
  intent         String?      // detected intent
  timestamp      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model Ticket {
  id           String   @id @default(uuid()) @db.Uuid
  ticketNumber String   @unique
  userId       String?  @db.Uuid
  sessionId    String?
  title        String
  description  String
  category     String
  priority     String   @default("medium") // low, medium, high, critical
  status       String   @default("open") // open, in-progress, resolved, closed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User?    @relation(fields: [userId], references: [id])
}

model Feedback {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @db.Uuid
  rating         Int          // 1 to 5
  comments       String?
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model AuditLog {
  logId        String   @id @default(uuid()) @db.Uuid
  userId       String?  @db.Uuid
  userRole     String?  // Admin, Counselor, Faculty, Staff
  actionType   String   // INSERT, UPDATE, DELETE, LOGIN, LOGOUT
  tableName    String
  recordId     String
  oldValue     Json?
  newValue     Json?
  changeReason String?
  ipAddress    String?
  deviceInfo   String?
  createdAt    DateTime @default(now())

  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tableName, recordId])
  @@index([actionType])
  @@index([createdAt])
}

// ─── Document Management System ──────────────────────────────────────────────

model DocumentCategory {
  id          String     @id @default(uuid()) @db.Uuid
  name        String     @unique
  description String?
  documents   Document[]
}

model Document {
  id           String   @id @default(uuid()) @db.Uuid
  title        String
  categoryId   String   @db.Uuid
  description  String
  keywords     String[] // PostgreSQL supports String[]
  academicYear String?
  department   String?
  version      String   @default("1.0")
  fileUrl      String
  fileType     String   // PDF, DOCX, XLSX
  fileSize     Int      // Size in bytes
  language     String   @default("English")
  status       String   @default("active") // active, archived
  uploadedById String?  @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category     DocumentCategory   @relation(fields: [categoryId], references: [id])
  uploadedBy   User?              @relation(fields: [uploadedById], references: [id])
  downloads    DocumentDownload[]

  @@index([title])
}

model DocumentDownload {
  id           String   @id @default(uuid()) @db.Uuid
  documentId   String   @db.Uuid
  userId       String?  @db.Uuid
  sessionId    String?
  downloadDate DateTime @default(now())

  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ─── AI Course Recommendation Models ──────────────────────────────────────────

model EligibilityCriteria {
  id                  String   @id @default(uuid()) @db.Uuid
  courseId            String   @unique @db.Uuid
  requiredQuals       String[] 
  allowedStreams      String[] 
  minPercentage       Float    
  description         String?

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Scholarship {
  id              String   @id @default(uuid()) @db.Uuid
  courseId        String?  @db.Uuid
  name            String
  description     String?
  eligibility     String
  minPercentage   Float?
  amount          String
  deadline        DateTime?

  course Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)
}

model Placement {
  id              String   @id @default(uuid()) @db.Uuid
  courseId        String   @unique @db.Uuid
  placementRate   Float    
  averageSalary   String   
  topRecruiters   String[]

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model CareerPath {
  id              String   @id @default(uuid()) @db.Uuid
  courseId        String   @db.Uuid
  roleName        String
  industryDemand  String?

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

// ─── Dashboard Gallery ────────────────────────────────────────────────────────

model GalleryImage {
  id          String   @id @default(uuid()) @db.Uuid
  url         String
  title       String
  description String?
  category    String   // "Hero", "Campus", "Featured", "Slider"
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Hostel Management ────────────────────────────────────────────────────────

model HostelRoom {
  id          String   @id @default(uuid()) @db.Uuid
  roomNumber  String
  block       String
  roomType    String
  totalBeds   Int
  status      String   @default("Available")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  allocations HostelAllocation[]
}

model HostelAllocation {
  id          String   @id @default(uuid()) @db.Uuid
  studentId   String   @db.Uuid
  roomId      String   @db.Uuid
  status      String   @default("Allocated")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student     Student    @relation(fields: [studentId], references: [id])
  room        HostelRoom @relation(fields: [roomId], references: [id])
}

// ─── Transport Management ─────────────────────────────────────────────────────

model TransportVehicle {
  id          String   @id @default(uuid()) @db.Uuid
  vehicleId   String   @unique
  type        String
  plateNumber String
  condition   String
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  routes      TransportRoute[]
}

model TransportRoute {
  id          String   @id @default(uuid()) @db.Uuid
  routeNo     String   @unique
  name        String
  path        String
  vehicleId   String?  @db.Uuid
  stops       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle     TransportVehicle? @relation(fields: [vehicleId], references: [id])
}

// ─── HR & Payroll Management ──────────────────────────────────────────────────

model PayrollRecord {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  month       String
  baseSalary  String
  allowances  String
  netPayable  String
  status      String   @default("Pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}

model LeaveRequest {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  type        String
  duration    String
  reason      String
  status      String   @default("Pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}

// --- Admissions, Fees & Examinations (Phase 4) ------------------------------

model AdmissionApplication {
  id        String   @id @default(uuid()) @db.Uuid
  appId     String   @unique
  name      String
  course    String
  date      String
  status    String   @default("Pending") // Pending, Approved, Rejected
  score     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeeRecord {
  id        String   @id @default(uuid()) @db.Uuid
  student   String
  course    String
  amount    String
  dueDate   String
  status    String   @default("Pending") // Paid, Pending, Overdue
  invoiceNo String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Examination {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  course    String
  date      String
  time      String
  room      String
  status    String   @default("Upcoming") // Upcoming, Ongoing, Completed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


// --- Library, Departments & Timetable (Phase 5) -----------------------------

model LibraryBook {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  author    String
  isbn      String   @unique
  category  String
  qty       Int      @default(1)
  status    String   @default("In Stock") // In Stock, Low Stock, Out of Stock
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  code      String   @unique
  hod       String?
  faculty   Int      @default(0)
  students  Int      @default(0)
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TimetableEntry {
  id        String   @id @default(uuid()) @db.Uuid
  day       String
  time      String
  subject   String
  faculty   String
  room      String
  course    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Announcement {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  content   String?
  audience  String
  status    String   @default("Published")
  createdAt DateTime @default(now())
}

model AppMessage {
  id        String   @id @default(uuid()) @db.Uuid
  type      String   // Email, SMS, Push Notification
  audience  String
  subject   String?
  body      String
  createdAt DateTime @default(now())
}
